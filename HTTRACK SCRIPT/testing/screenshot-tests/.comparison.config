# Screenshot Comparison Configuration
# Edit this file to customize comparison settings

# Base URLs
PROD_BASE_URL=https://www.meandmbc.gr
PREVIEW_BASE_URL=https://pfelmeandmbcgr-preview.pfizerstatic.io

# Sitemap URL (fetched from preview environment)
SITEMAP_URL=https://pfelmeandmbcgr-preview.pfizerstatic.io/sitemap.xml

# Viewport configurations (width x height)
# Format: name:width:height
VIEWPORTS=desktop:1920:1080,tablet:768:1024,mobile:375:667

# Screenshot settings
WAIT_FOR_NETWORK_IDLE=true
WAIT_TIME_MS=2000
TIMEOUT_MS=30000
FULL_PAGE=true

# Comparison settings
PIXELMATCH_THRESHOLD=0.1
DIFF_FAIL_PERCENTAGE=5

# Output directories
SCREENSHOTS_DIR=./screenshots
COMPARISON_DIR=./comparison-results

# Browser settings
HEADLESS=true
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/91.0.4472.124 Safari/537.36

# Report settings
GENERATE_HTML_REPORT=true
GENERATE_JSON_SUMMARY=true
INCLUDE_DIFF_IMAGES=true

# Advanced options
PARALLEL_EXECUTION=false
MAX_WORKERS=1
RETRY_ON_FAILURE=true
MAX_RETRIES=2
